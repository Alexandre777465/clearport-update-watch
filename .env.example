# ────────────────────────────────────────────────────────────────────────────
# ClearPort — Frontend environment variables
# Copy this file to .env.local for local development.
# In Lovable / Cloudflare Pages: add these as environment variables in your
# project settings. VITE_ variables are injected at build time (public).
# Non-VITE_ variables are only available in server functions (private).
# ────────────────────────────────────────────────────────────────────────────

# ── Supabase (optional) ──────────────────────────────────────────────────────
# Required to authenticate against the backend REST API.
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Backend API (optional) ───────────────────────────────────────────────────
# The URL of the running Express backend (server/).
# When not set the frontend uses built-in mock data — it still works fully.
# Example (local):    http://localhost:3000
# Example (deployed): https://api.clearport.io
VITE_API_URL=

# ── Anthropic — Ask ClearPort server function (optional) ─────────────────────
# Server-side only (no VITE_ prefix). The Ask ClearPort chat calls Anthropic
# directly from Cloudflare Workers when this key is set.
# Without it the chat falls back to the built-in keyword mock.
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── For Cloudflare Workers ───────────────────────────────────────────────────
# Add ANTHROPIC_API_KEY as a secret:
#   npx wrangler secret put ANTHROPIC_API_KEY
# Add VITE_* variables in:
#   Cloudflare Dashboard → Workers & Pages → your project → Settings → Variables
