# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Anthropic (for summarization + tagging)
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email alerts)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alerts@clearport.io
RESEND_FROM_NAME=ClearPort Alerts

# App
PORT=3000
NODE_ENV=development
APP_URL=https://app.clearport.io
# Comma-separated list of allowed CORS origins (leave blank to allow all)
ALLOWED_ORIGINS=http://localhost:5173,https://app.clearport.io

# Feature flags
ENABLE_EMAIL_ALERTS=true
